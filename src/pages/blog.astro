---
import BlogCard from '../components/BlogCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

type PostModule = {
  frontmatter: {
    title: string;
    description?: string;
    author?: string;
    pubDate?: string;
    date?: string;
    tags?: string[];
  };
  url: string;
};

const posts = Object.values(import.meta.glob('./posts/*.md', { eager: true })) as PostModule[];

posts.sort((left: PostModule, right: PostModule) => {
  const leftPublished = left.frontmatter.pubDate ?? left.frontmatter.date ?? '';
  const rightPublished = right.frontmatter.pubDate ?? right.frontmatter.date ?? '';

  return new Date(rightPublished).getTime() - new Date(leftPublished).getTime();
});

const pageTitle = "Pustak Blog";
---

<BaseLayout title={pageTitle} description="Quick notes from the things you read during the day." currentPath={Astro.url.pathname}>
  <section class="hero">
    <p class="eyebrow">{pageTitle}</p>
    <h1>Quick notes from the things you read during the day.</h1>
    <p class="lead">Use this page for articles, essays, and small reflections you want to keep in one place.</p>
  </section>

  <section class="blog-grid" aria-label="All posts">
    {posts.map((post) => <BlogCard post={post} />)}
  </section>
</BaseLayout>
