---
const entries = [
	{ title: 'Morning reading', text: 'A short note on the article or chapter you started with today.' },
	{ title: 'Midday ideas', text: 'A place for quotes, links, and anything worth remembering.' },
	{ title: 'Evening recap', text: 'Wrap up the day with what you read and what you want to return to.' },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Pustak Blog</title>
  </head>
  <body>
    <main class="shell">
      <nav class="nav" aria-label="Primary">
        <a href="/">Home</a>
        <a href="/about/">About</a>
        <a href="/blog/">Blog</a>
      </nav>

      <section class="hero">
        <p class="eyebrow">Reading log</p>
        <h1>Quick notes from the things you read during the day.</h1>
        <p class="lead">Use this page for articles, essays, and small reflections you want to keep in one place.</p>
      </section>

      <section class="grid" aria-label="Daily reading notes">
        {entries.map((entry) => (
          <article class="card">
            <h2>{entry.title}</h2>
            <p>{entry.text}</p>
          </article>
        ))}
      </section>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family: Inter, system-ui, sans-serif;
    background: linear-gradient(180deg, #f8f3ea 0%, #fffaf3 100%);
    color: #1f2937;
  }

  .shell {
    max-width: 960px;
    margin: 0 auto;
    padding: 32px 20px 56px;
  }

  .nav {
    display: flex;
    gap: 20px;
    margin-bottom: 48px;
    font-size: 0.95rem;
  }

  .nav a {
    color: #6b4f36;
    text-decoration: none;
  }

  .hero {
    padding: 40px 0 28px;
  }

  .eyebrow {
    margin: 0 0 12px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.78rem;
    color: #a16207;
  }

  h1 {
    margin: 0;
    max-width: 13ch;
    font-size: clamp(2.3rem, 6vw, 4.2rem);
    line-height: 0.98;
  }

  .lead {
    max-width: 56ch;
    margin: 18px 0 0;
    font-size: 1.08rem;
    line-height: 1.7;
    color: #4b5563;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
    margin-top: 34px;
  }

  .card {
    padding: 20px;
    border: 1px solid rgba(107, 79, 54, 0.14);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.78);
    backdrop-filter: blur(8px);
    box-shadow: 0 12px 30px rgba(107, 79, 54, 0.08);
  }

  .card h2 {
    margin: 0 0 10px;
    font-size: 1.1rem;
  }

  .card p {
    margin: 0;
    line-height: 1.65;
    color: #4b5563;
  }

  @media (max-width: 640px) {
    .nav {
      margin-bottom: 32px;
    }

    h1 {
      max-width: none;
    }
  }
</style>
