---
const entries = [
	{ title: 'Morning reading', text: 'A short note on the article or chapter you started with today.' },
	{ title: 'Midday ideas', text: 'A place for quotes, links, and anything worth remembering.' },
	{ title: 'Evening recap', text: 'Wrap up the day with what you read and what you want to return to.' },
];
const pageTitle = "Pustak Blog";

import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title={pageTitle} description="Quick notes from the things you read during the day." currentPath={Astro.url.pathname}>
  <section class="hero">
    <p class="eyebrow">{pageTitle}</p>
    <h1>Quick notes from the things you read during the day.</h1>
    <p class="lead">Use this page for articles, essays, and small reflections you want to keep in one place.</p>
  </section>

  <section class="links">
    <ul>
      <li><a href="/posts/post-1/">Post 1</a></li>
      <li><a href="/posts/post-2/">Post 2</a></li>
      <li><a href="/posts/post-3/">Post 3</a></li>
      <li><a href="/posts/post-4/">Post 4</a></li>
    </ul>
  </section>

  <section class="grid" aria-label="Daily reading notes">
    {entries.map((entry) => (
      <article class="card">
        <h2>{entry.title}</h2>
        <p>{entry.text}</p>
      </article>
    ))}
  </section>
</BaseLayout>
