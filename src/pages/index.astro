---
const readingLists = [
	{
		title: 'Love',
		description: 'Books that stayed with you long after the last page.',
	},
	{
		title: 'To Read',
		description: 'A short list of books waiting for the right moment.',
	},
	{
		title: 'Already Read',
		description: 'Finished books, quick thoughts, and favorite lines.',
	},
];
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Pustak" description="A simple place to keep the books you love and the ones you want next." currentPath={Astro.url.pathname}>
	<section class="hero">
		<p class="eyebrow">Pustak</p>
		<h1>A simple place to keep the books you love and the ones you want next.</h1>
		<p class="lead">Track what you have read, what you are reading, and the articles you collect through the day.</p>
	</section>

	<section class="grid" aria-label="Reading lists">
		{readingLists.map((item) => (
			<article class="card">
				<h2>{item.title}</h2>
				<p>{item.description}</p>
			</article>
		))}
	</section>
</BaseLayout>
